# Copie este arquivo para .env e preencha os valores reais
# cp .env.example .env

# ─── Banco de dados ──────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/faam
DB_USERNAME=faam_user
DB_PASSWORD=sua_senha_aqui

# ─── JWT ─────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 64
JWT_SECRET=substitua-por-chave-secreta-minimo-64-chars-aqui
JWT_EXPIRATION_MS=86400000

# ─── Cloudflare R2 ───────────────────────────────────────────────
R2_ENDPOINT=https://SEU_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY=sua_access_key_aqui
R2_SECRET_KEY=sua_secret_key_aqui
R2_BUCKET=faam-attachments
R2_PUBLIC_URL=https://pub-SEU_HASH.r2.dev

# ─── Servidor ────────────────────────────────────────────────────
SERVER_PORT=8080
ALLOWED_ORIGINS=http://localhost:3000
